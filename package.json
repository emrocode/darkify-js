{
  "name": "darkify-js",
  "version": "1.1.13-beta.2",
  "description": "A simple dark mode toggle library",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/darkify.esm.js",
      "require": "./dist/darkify.umd.js",
      "types": "./dist/darkify.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.esm.js",
      "require": "./dist/plugins/index.umd.js",
      "types": "./dist/plugins/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "_cls": "rm -rf dist",
    "_bundle": "rollup -c rollup.config.ts --configPlugin typescript",
    "build": "npm run _cls && npm run _bundle",
    "format": "prettier --write src/",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest",
    "demo": "npm run build && sh demo.sh",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emrocode/darkify-js"
  },
  "keywords": [
    "dark mode",
    "light mode",
    "theme toggle",
    "dark theme",
    "color scheme",
    "theme switcher",
    "night mode",
    "automatic theme"
  ],
  "author": "Emilio Romero <emrocode@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "rollup": "^4.60.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3"
  }
}
